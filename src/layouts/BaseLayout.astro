---
import '../styles/global.css';
import { getProject } from '../lib/projects.ts';
import { canAccessProject, getAuthEmail, isEC } from '../lib/access.ts';

interface Props {
  title: string;
  headerCrumb?: string;
}

const { title, headerCrumb } = Astro.props;
const email = getAuthEmail(Astro.request);
const userIsEC = email ? isEC(email) : false;

// Derive project context from the URL path so any page nested under
// /[project]/* gets a header reference-doc menu without needing to thread
// project state through props.
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const projectSlug = pathSegments[0];

let projectContext: {
  slug: string;
  title: string;
  engagement: string;
  references: { slug: string; title: string }[];
} | null = null;

if (projectSlug && email) {
  const project = getProject(projectSlug);
  if (project && canAccessProject(email, project)) {
    projectContext = {
      slug: projectSlug,
      title: project.title,
      engagement: project.engagement ?? '',
      references: project.references,
    };
  }
}
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — EC</title>
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png" />
    <link rel="manifest" href="/favicons/site.webmanifest" />
    <link rel="shortcut icon" href="/favicons/favicon.ico" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <div class="site-header-left">
          <a href="/" class="site-title">
            <img class="site-title-mark" src="/favicons/apple-touch-icon.png" alt="" width="28" height="28" />
            <span>Electric Citizen</span>
          </a>
          {projectContext ? (
            <>
              <span class="site-header-sep" aria-hidden="true">/</span>
              <a href={`/${projectContext.slug}`} class="site-header-project">{projectContext.title}</a>
              {projectContext.engagement && (
                <span class="site-header-engagement">{projectContext.engagement}</span>
              )}
            </>
          ) : headerCrumb && (
            <>
              <span class="site-header-sep" aria-hidden="true">/</span>
              <span class="site-header-project">{headerCrumb}</span>
            </>
          )}
        </div>

        <div class="site-header-right">
          {projectContext && projectContext.references.length > 0 && (
            <details class="header-refs">
              <summary class="header-refs-trigger">
                <span>Reference documents</span>
                <svg class="header-refs-caret" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </summary>
              <div class="header-refs-menu" role="menu">
                <span class="header-refs-menu-label">{projectContext.title}{projectContext.engagement ? ` — ${projectContext.engagement}` : ''}</span>
                <ul>
                  {projectContext.references.map((r) => (
                    <li>
                      <a href={`/${projectContext!.slug}/reference/${r.slug}`} role="menuitem">{r.title}</a>
                    </li>
                  ))}
                </ul>
              </div>
            </details>
          )}
          {projectContext && (
            <form class="header-search" action={`/${projectContext.slug}/search`} method="get" role="search">
              <input
                type="search"
                name="q"
                placeholder="Search…"
                aria-label="Search this project"
                autocomplete="off"
              />
              <button
                type="submit"
                class="header-search-toggle"
                aria-label="Search"
                aria-expanded="false"
                title="Search"
              >
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="11" cy="11" r="7"/>
                  <path d="m20 20-3.5-3.5"/>
                </svg>
              </button>
            </form>
          )}
          {projectContext && (
            <a
              class="header-bell"
              href={`/${projectContext.slug}/notifications`}
              aria-label="Notification settings"
              title="Notification settings"
            >
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
                <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
              </svg>
            </a>
          )}
          {projectContext && userIsEC && (
            <button
              type="button"
              class="presenter-toggle"
              data-role="presenter-toggle"
              aria-pressed="false"
              aria-label="Hide internal comments"
              title="Hide internal (EC-only) comments — useful when sharing your screen"
            >
              <svg class="presenter-icon presenter-icon-eye-off" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                <line x1="2" y1="2" x2="22" y2="22"/>
              </svg>
              <svg class="presenter-icon presenter-icon-eye" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          )}
        </div>
      </div>
    </header>
    <main class="site-main">
      <div class="wrap">
        <slot />
      </div>
    </main>
    <button
      type="button"
      class="scroll-top"
      aria-label="Scroll to top"
      title="Scroll to top"
      hidden
    >
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19V5"/>
        <path d="m5 12 7-7 7 7"/>
      </svg>
    </button>
    <footer class="site-footer">
      <div class="wrap">
        <span>Electric Citizen</span>
        <span class="sep">·</span>
        <a href="https://github.com/electriccitizen/discovery">GitHub</a>
      </div>
    </footer>
    <script>
      import '../scripts/discovery.ts';
      // Close the header reference menu when clicking outside.
      document.addEventListener('click', (e) => {
        const refs = document.querySelector('details.header-refs');
        if (!refs || !refs.hasAttribute('open')) return;
        if (!(e.target instanceof Node) || !refs.contains(e.target)) {
          refs.removeAttribute('open');
        }
      });

      // Header search: icon expands to input on click. Submit on Enter or
      // a second click of the icon (when populated). Esc or outside-click
      // (when empty) collapses.
      (() => {
        const form = document.querySelector('.header-search');
        if (!(form instanceof HTMLFormElement)) return;
        const toggle = form.querySelector('.header-search-toggle');
        const input = form.querySelector('input[type=search]');
        if (!(toggle instanceof HTMLButtonElement)) return;
        if (!(input instanceof HTMLInputElement)) return;
        const open = () => {
          form.classList.add('is-open');
          toggle.setAttribute('aria-expanded', 'true');
          input.focus();
        };
        const close = () => {
          form.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
        };
        toggle.addEventListener('click', (e) => {
          if (!form.classList.contains('is-open')) {
            e.preventDefault();
            open();
            return;
          }
          if (!input.value.trim()) {
            e.preventDefault();
            close();
          }
          // else let the submit happen
        });
        input.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            input.value = '';
            close();
            toggle.focus();
          }
        });
        document.addEventListener('click', (e) => {
          if (!form.classList.contains('is-open')) return;
          if (!(e.target instanceof Node) || form.contains(e.target)) return;
          if (!input.value.trim()) close();
        });
      })();

      // Welcome panel: persist collapse state via a per-project cookie
      // (24h max-age, roughly aligned with a Cloudflare Access session).
      // Server reads the cookie and renders the right state, so this only
      // has to write on user toggle.
      document.querySelectorAll('.welcome-collapsible').forEach((el) => {
        if (!(el instanceof HTMLDetailsElement)) return;
        const name = el.dataset.cookieName;
        if (!name) return;
        el.addEventListener('toggle', () => {
          const value = el.open ? '0' : '1';
          document.cookie = `${name}=${value}; path=/; max-age=86400; SameSite=Lax`;
        });
      });

      // Panel collapse: "Show N more" toggles the overflow items on a
      // collapsible list (currently the priority panel). Each button is
      // paired with the immediately-preceding .panel-collapsible list.
      document.querySelectorAll('.panel-expand').forEach((btn) => {
        if (!(btn instanceof HTMLButtonElement)) return;
        const list = btn.previousElementSibling;
        if (!(list instanceof HTMLElement) || !list.classList.contains('panel-collapsible')) return;
        const moreLabel = btn.dataset.moreLabel || 'Show more';
        const lessLabel = btn.dataset.lessLabel || 'Show fewer';
        btn.addEventListener('click', () => {
          const expanded = list.dataset.collapsed === 'false';
          list.dataset.collapsed = expanded ? 'true' : 'false';
          btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
          btn.textContent = expanded ? moreLabel : lessLabel;
        });
      });

      // Presenter mode: hide internal (EC-only) comments via a body-level
      // attribute so the screen-share view doesn't expose private notes.
      // Server-side filtering still applies for non-EC viewers; this is
      // purely a presenter convenience for EC users.
      //
      // Button is icon-only: eye-off (default, "click to hide") swaps to
      // eye ("click to reveal") when internal is hidden. CSS handles which
      // icon shows based on aria-pressed.
      (() => {
        const STORAGE_KEY = 'discovery.presenter.hideInternal';
        const btn = document.querySelector('[data-role="presenter-toggle"]');
        const apply = (on: boolean) => {
          document.body.dataset.hideInternal = on ? '1' : '0';
          if (btn instanceof HTMLButtonElement) {
            btn.setAttribute('aria-pressed', on ? 'true' : 'false');
            btn.setAttribute(
              'aria-label',
              on ? 'Show internal comments' : 'Hide internal comments'
            );
            btn.setAttribute(
              'title',
              on
                ? 'Currently hiding internal comments — click to show'
                : 'Hide internal (EC-only) comments — useful when sharing your screen'
            );
          }
        };
        // Read persisted state on every page (toggle button may or may not be
        // present — non-EC viewers won't see it, but the body class can stay
        // off either way since they can't see internal anyway).
        const persisted = localStorage.getItem(STORAGE_KEY) === '1';
        apply(persisted);
        if (btn instanceof HTMLButtonElement) {
          btn.addEventListener('click', () => {
            const next = document.body.dataset.hideInternal !== '1';
            localStorage.setItem(STORAGE_KEY, next ? '1' : '0');
            apply(next);
          });
        }
        // Shift+H toggles. Skip when focus is in an editable field so it
        // doesn't fight typing.
        document.addEventListener('keydown', (e) => {
          if (!btn) return;
          if (!e.shiftKey || e.key !== 'H' || e.ctrlKey || e.metaKey || e.altKey) return;
          const t = e.target as HTMLElement | null;
          if (t && (t.tagName === 'TEXTAREA' || t.tagName === 'INPUT' || t.isContentEditable)) return;
          e.preventDefault();
          (btn as HTMLButtonElement).click();
        });
      })();

      // Scroll-to-top button: reveal after 300px, smooth-scroll on click
      // (or instant if the user prefers reduced motion).
      (() => {
        const btn = document.querySelector('.scroll-top');
        if (!(btn instanceof HTMLButtonElement)) return;
        const threshold = 300;
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
        const update = () => {
          const show = window.scrollY > threshold;
          btn.hidden = !show;
          btn.classList.toggle('is-visible', show);
        };
        update();
        window.addEventListener('scroll', update, { passive: true });
        btn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: reduce.matches ? 'auto' : 'smooth' });
        });
      })();
    </script>
  </body>
</html>
