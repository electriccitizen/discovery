---
import '../styles/global.css';
import { getProject } from '../lib/projects.ts';
import { canAccessProject } from '../lib/access.ts';

interface Props {
  title: string;
}

const { title } = Astro.props;
const email = Astro.request.headers.get('cf-access-authenticated-user-email');
const isEC = email?.endsWith('@electriccitizen.com') ?? false;
const userLabel = email ? (isEC ? 'EC' : 'Client') : null;

// Derive project context from the URL path so any page nested under
// /[project]/* gets a header reference-doc menu without needing to thread
// project state through props.
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const projectSlug = pathSegments[0];

let projectContext: {
  slug: string;
  title: string;
  references: { slug: string; title: string }[];
} | null = null;

if (projectSlug && email) {
  const project = getProject(projectSlug);
  if (project && canAccessProject(email, project) && project.references.length > 0) {
    projectContext = {
      slug: projectSlug,
      title: project.title,
      references: project.references,
    };
  }
}
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — EC</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <div class="site-header-left">
          <a href="/" class="site-title">Electric Citizen</a>
          {projectContext && (
            <>
              <span class="site-header-sep" aria-hidden="true">/</span>
              <a href={`/${projectContext.slug}`} class="site-header-project">{projectContext.title}</a>
              <form class="header-search" action={`/${projectContext.slug}/search`} method="get" role="search">
                <input
                  type="search"
                  name="q"
                  placeholder="Search…"
                  aria-label="Search this project"
                  autocomplete="off"
                />
              </form>
            </>
          )}
        </div>

        <div class="site-header-right">
          {projectContext && (
            <details class="header-refs">
              <summary class="header-refs-trigger">
                <span>Reference documents</span>
                <span class="header-refs-caret" aria-hidden="true">▾</span>
              </summary>
              <div class="header-refs-menu" role="menu">
                <span class="header-refs-menu-label">{projectContext.title}</span>
                <ul>
                  {projectContext.references.map((r) => (
                    <li>
                      <a href={`/${projectContext!.slug}/reference/${r.slug}`} role="menuitem">{r.title}</a>
                    </li>
                  ))}
                </ul>
              </div>
            </details>
          )}
          {email && (
            <span class="user-chip">
              <span class={`user-role user-role-${isEC ? 'ec' : 'client'}`}>{userLabel}</span>
              <span class="user-email">{email}</span>
            </span>
          )}
        </div>
      </div>
    </header>
    <main class="site-main">
      <div class="wrap">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <span>Electric Citizen</span>
        <span class="sep">·</span>
        <a href="https://github.com/electriccitizen/discovery">GitHub</a>
      </div>
    </footer>
    <script>
      import '../scripts/discovery.ts';
      // Close the header reference menu when clicking outside.
      document.addEventListener('click', (e) => {
        const refs = document.querySelector('details.header-refs');
        if (!refs || !refs.hasAttribute('open')) return;
        if (!(e.target instanceof Node) || !refs.contains(e.target)) {
          refs.removeAttribute('open');
        }
      });
    </script>
  </body>
</html>
