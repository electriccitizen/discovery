---
import type { Question } from '../lib/worksheet.ts';
import {
  PRIORITY_VALUES,
  type AuditRow,
  type CommentRow,
  type Priority,
  type ResponseRow,
  type Status,
} from '../lib/db.ts';
import { isEC } from '../lib/access.ts';
import CommentThread from './CommentThread.astro';
import AuditHistory from './AuditHistory.astro';

interface Props {
  question: Question;
  projectSlug: string;
  response: ResponseRow | null;
  comments: CommentRow[];
  audit: AuditRow[];
}

const { question, projectSlug, response, comments, audit } = Astro.props;

const userEmail = Astro.request.headers.get('cf-access-authenticated-user-email');
const userIsEC = userEmail ? isEC(userEmail) : false;

const bodyValue = response?.body ?? '';
const status: Status = (response?.status as Status) ?? 'not_started';
const priority: Priority = (response?.priority as Priority) ?? 'medium';

const PRIORITY_LABELS: Record<Priority, string> = {
  high: 'High',
  medium: 'Med',
  low: 'Low',
};

const updatedDisplay = response
  ? new Date(response.updated_at).toLocaleString(undefined, {
      dateStyle: 'medium',
      timeStyle: 'short',
    })
  : null;

const isAnswered = status === 'answered';
const isFlagged = status === 'needs_clarification';
const showChip = isAnswered || isFlagged;
---
<article class={`question-card status-${status} priority-${priority}`} id={question.id}>
  <header class="question-card-header">
    <span class="question-id">{question.id}</span>
    <h3 class="question-title">{question.title}</h3>
    <div class="question-card-header-right">
      <span
        class={`status-chip status-chip-${status}`}
        data-role="status-chip"
        hidden={!showChip}
      >
        {isAnswered ? 'Answered' : isFlagged ? 'Needs clarification' : ''}
      </span>
      {userIsEC && (
        <priority-strip class="priority-strip" data-project={projectSlug} data-question-id={question.id}>
          <span class="priority-strip-label">Priority</span>
          {PRIORITY_VALUES.map((p) => (
            <button
              type="button"
              data-priority={p}
              class={`priority-mini priority-mini-${p}${priority === p ? ' selected' : ''}`}
            >{PRIORITY_LABELS[p]}</button>
          ))}
        </priority-strip>
      )}
    </div>
  </header>

  {question.bodyHtml && (
    <div class="question-body" set:html={question.bodyHtml} />
  )}

  {question.whyHtml && (
    <aside class="question-meta question-why">
      <span class="meta-label">Why we ask</span>
      <span class="meta-body" set:html={question.whyHtml} />
    </aside>
  )}

  {question.expectedHtml && (
    <aside class="question-meta question-expected">
      <span class="meta-label">Expected format</span>
      <span class="meta-body" set:html={question.expectedHtml} />
    </aside>
  )}

  <response-form class="response-form" data-project={projectSlug} data-question-id={question.id}>
    <label class="response-label">
      <span class="response-label-text">Your response</span>
      <textarea
        rows="4"
        placeholder="Type your response. Saves automatically."
      >{bodyValue}</textarea>
    </label>
    <div class="response-footer">
      <span class="save-indicator" data-state="idle">{bodyValue ? 'Saved' : ''}</span>
      {updatedDisplay && (
        <span class="response-meta">Last updated {updatedDisplay} by <code>{response?.updated_by}</code></span>
      )}
    </div>
  </response-form>

  <status-toggle
    class="status-toggle"
    data-project={projectSlug}
    data-question-id={question.id}
    data-status={status}
  >
    <button
      type="button"
      class={`status-action status-action-answered${isAnswered ? ' selected' : ''}`}
      data-action="toggle-answered"
    >
      <span class="status-action-label-default">Mark as answered</span>
      <span class="status-action-label-selected">Answered</span>
    </button>
    <button
      type="button"
      class={`status-action status-action-clarification${isFlagged ? ' selected' : ''}`}
      data-action="toggle-clarification"
    >
      <span class="status-action-label-default">Flag for clarification</span>
      <span class="status-action-label-selected">Flagged — needs clarification</span>
    </button>
  </status-toggle>

  <AuditHistory audit={audit} />

  <CommentThread projectSlug={projectSlug} questionId={question.id} comments={comments} />
</article>
