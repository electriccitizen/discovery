---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatProjectTitle, getIntroHtml, getProject } from '../../lib/projects.ts';
import { listSections, countQuestions } from '../../lib/worksheet.ts';
import { listRecentActivity, listResponses, type ActivityItem } from '../../lib/db.ts';
import { canAccessProject, isEC, getAuthEmail } from '../../lib/access.ts';
import { env } from 'cloudflare:workers';

const projectSlug = Astro.params.project;
if (!projectSlug) return new Response(null, { status: 404 });

const project = getProject(projectSlug);
if (!project) return new Response(null, { status: 404 });

const userEmail = getAuthEmail(Astro.request);
if (!userEmail || !canAccessProject(userEmail, project)) {
  return new Response(null, { status: 404 });
}
const userIsEC = isEC(userEmail);

const introHtml = getIntroHtml(projectSlug);

const sections = listSections(projectSlug);
const totalQuestions = countQuestions(projectSlug);

const db = env.DB;
const [responses, activity] = db
  ? await Promise.all([
      listResponses(db, projectSlug),
      listRecentActivity(db, projectSlug, 10, { includeInternal: userIsEC }),
    ])
  : [[], [] as ActivityItem[]];
const responsesById = new Map(responses.map((r) => [r.question_id, r]));

const sectionByLetter = new Map(sections.map((s) => [s.id, s]));
function questionLink(qid: string): string {
  const letter = qid.match(/^([A-Z])/)?.[1];
  const section = letter ? sectionByLetter.get(letter) : undefined;
  return section ? `/${projectSlug}/section/${section.slug}#${qid}` : '#';
}

// Welcome panel state: read the per-project collapse cookie server-side
// so the rendered HTML is already in the right state — no flash.
const cookieHeader = Astro.request.headers.get('cookie') ?? '';
const welcomeCookieName = `discovery-welcome-${projectSlug}`;
const welcomeCollapsed = cookieHeader
  .split(';')
  .some((c) => c.trim().startsWith(`${welcomeCookieName}=1`));

const ecDomain = '@electriccitizen.com';
function labelFor(email: string): 'EC' | string {
  return email.toLowerCase().endsWith(ecDomain) ? 'EC' : project.client.label;
}
function roleClass(email: string): 'ec' | 'client' {
  return email.toLowerCase().endsWith(ecDomain) ? 'ec' : 'client';
}
function fmtTime(iso: string): string {
  return new Date(iso).toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' });
}
function preview(s: string, max = 140): string {
  const trimmed = s.replace(/\s+/g, ' ').trim();
  return trimmed.length > max ? trimmed.slice(0, max - 1) + '…' : trimmed;
}

const statusCounts = {
  not_started: 0,
  in_progress: 0,
  answered: 0,
};

interface SurfacedQuestion {
  questionId: string;
  questionTitle: string;
  sectionId: string;
  sectionTitle: string;
  sectionSlug: string;
}
const flaggedQuestions: SurfacedQuestion[] = [];

for (const section of sections) {
  for (const q of section.questions) {
    const r = responsesById.get(q.id);
    const rawStatus = r?.status ?? 'not_started';
    // Defensive: any historical row that still carries the retired
    // 'needs_clarification' value (or any unknown future value) is
    // bucketed under 'in_progress' for the counter.
    const s = (rawStatus in statusCounts ? rawStatus : 'in_progress') as keyof typeof statusCounts;
    statusCounts[s]++;
    if ((r?.flagged ?? 0) === 1) {
      flaggedQuestions.push({
        questionId: q.id,
        questionTitle: q.title,
        sectionId: section.id,
        sectionTitle: section.title,
        sectionSlug: section.slug,
      });
    }
  }
}

const answeredCount = statusCounts.answered;
const completionPct = totalQuestions > 0 ? Math.round((answeredCount / totalQuestions) * 100) : 0;

function sectionStats(sectionId: string) {
  const section = sections.find((s) => s.id === sectionId);
  if (!section) return { answered: 0, total: 0 };
  let answered = 0;
  for (const q of section.questions) {
    if (responsesById.get(q.id)?.status === 'answered') answered++;
  }
  return { answered, total: section.questions.length };
}
---
<BaseLayout title={formatProjectTitle(project)}>
  {userIsEC && (
    <div class="page-meta">
      <p class="breadcrumb"><a href="/">Discovery Portal</a></p>
      <a
        class="edit-on-github"
        href={`https://github.com/electriccitizen/discovery/edit/main/content/projects/${projectSlug}/_intro.md`}
        target="_blank"
        rel="noopener noreferrer"
      >Edit on GitHub <span class="edit-on-github-arrow" aria-hidden="true">↗</span></a>
    </div>
  )}
  <dl class="project-meta-block">
    <div><dt>Client</dt><dd>{project.client.name}</dd></div>
    <div><dt>Primary contact</dt><dd>{project.client.primary_contact}</dd></div>
    <div><dt>Status</dt><dd>{project.status}</dd></div>
    <div><dt>Scope</dt><dd>{totalQuestions} questions · {sections.length} sections</dd></div>
  </dl>

  {introHtml && (
    <details class="project-intro welcome-collapsible" data-cookie-name={welcomeCookieName} open={!welcomeCollapsed}>
      <summary class="welcome-summary">
        <span class="welcome-summary-label">Welcome</span>
        <span class="welcome-summary-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </span>
      </summary>
      <div class="welcome-body" set:html={introHtml} />
    </details>
  )}

  <section class="progress-block">
    <div class="progress-headline">
      <span class="progress-pct">{completionPct}%</span>
      <span class="progress-label">
        {answeredCount} of {totalQuestions} answered
      </span>
    </div>
    <div class="progress-bar">
      <div class="progress-bar-fill" style={`width: ${completionPct}%`}></div>
    </div>
    <dl class="progress-status-breakdown">
      <div class="grid-header">Status</div>
      <div><dt>Not started</dt><dd>{statusCounts.not_started}</dd></div>
      <div><dt>In progress</dt><dd>{statusCounts.in_progress}</dd></div>
      <div><dt>Answered</dt><dd>{statusCounts.answered}</dd></div>
    </dl>
  </section>

  {flaggedQuestions.length > 0 && (
    <section class="priority-panel">
      <div class="priority-panel-header">
        <span class="priority-panel-tag">Priority</span>
        <h2 class="priority-panel-title">
          {flaggedQuestions.length === 1
            ? 'EC has flagged 1 question for your attention'
            : `EC has flagged ${flaggedQuestions.length} questions for your attention`}
        </h2>
      </div>
      <ol class="priority-panel-list panel-collapsible" data-collapsed={flaggedQuestions.length > 5 ? 'true' : 'false'}>
        {flaggedQuestions.map((q, i) => (
          <li class={i >= 5 ? 'panel-overflow-item' : ''}>
            <a href={`/${projectSlug}/section/${q.sectionSlug}#${q.questionId}`}>
              <span class="priority-panel-qid">{q.questionId}</span>
              <span class="priority-panel-qtitle">{q.questionTitle}</span>
              <span class="priority-panel-section">{q.sectionId}. {q.sectionTitle}</span>
            </a>
          </li>
        ))}
      </ol>
      {flaggedQuestions.length > 5 && (
        <button
          type="button"
          class="panel-expand"
          aria-expanded="false"
          data-more-label={`Show ${flaggedQuestions.length - 5} more`}
          data-less-label="Show fewer"
        >Show {flaggedQuestions.length - 5} more</button>
      )}
    </section>
  )}

  <h2>Worksheet sections</h2>
  <ol class="section-list">
    {sections.map((s) => {
      const stats = sectionStats(s.id);
      const isComplete = stats.total > 0 && stats.answered === stats.total;
      return (
        <li class={isComplete ? 'is-complete' : undefined}>
          <a href={`/${projectSlug}/section/${s.slug}`}>
            <span class="section-id">{s.id}</span>
            <span class="section-title">{s.title}</span>
            <span class="section-count">
              {stats.answered}/{stats.total}
            </span>
          </a>
        </li>
      );
    })}
  </ol>

  {activity.length > 0 && (
    <section class="activity-block">
      <h2>Recent activity</h2>
      <ol class="activity-list panel-collapsible" data-collapsed={activity.length > 3 ? 'true' : 'false'}>
        {activity.map((a, i) => (
          <li class={`activity-item activity-${a.kind} role-${roleClass(a.author_email)}${a.kind === 'comment' && a.internal === 1 ? ' activity-item--internal' : ''}${i >= 3 ? ' panel-overflow-item' : ''}`}>
            <div class="activity-meta">
              <a class="activity-question" href={questionLink(a.question_id)}>{a.question_id}</a>
              <span class={`user-role user-role-${roleClass(a.author_email)}`}>{labelFor(a.author_email)}</span>
              {a.kind === 'comment' && a.internal === 1 && (
                <span class="comment-internal-badge" title="Internal — EC team only, not visible to client">INTERNAL</span>
              )}
              <span class="activity-action">
                {a.kind === 'comment' ? 'commented' : 'edited response'}
              </span>
              <time class="activity-time" datetime={a.at}>{fmtTime(a.at)}</time>
            </div>
            <p class="activity-preview">{preview(a.body)}</p>
          </li>
        ))}
      </ol>
      {activity.length > 3 && (
        <button
          type="button"
          class="panel-expand"
          aria-expanded="false"
          data-more-label={`Show ${activity.length - 3} more`}
          data-less-label="Show fewer"
        >Show {activity.length - 3} more</button>
      )}
    </section>
  )}

</BaseLayout>
