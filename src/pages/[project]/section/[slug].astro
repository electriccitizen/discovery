---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getProject } from '../../../lib/projects.ts';
import { getSection, listSections } from '../../../lib/worksheet.ts';
import {
  listAllAudit,
  listAllComments,
  listResponses,
  type AuditRow,
  type CommentRow,
} from '../../../lib/db.ts';
import { canAccessProject, isEC, getAuthEmail } from '../../../lib/access.ts';
import { env } from 'cloudflare:workers';
import QuestionCard from '../../../components/QuestionCard.astro';

const projectSlug = Astro.params.project;
const sectionSlug = Astro.params.slug;
if (!projectSlug || !sectionSlug) return new Response(null, { status: 404 });

const project = getProject(projectSlug);
const section = getSection(projectSlug, sectionSlug);
if (!project || !section) return new Response(null, { status: 404 });

const userEmail = getAuthEmail(Astro.request);
if (!userEmail || !canAccessProject(userEmail, project)) {
  return new Response(null, { status: 404 });
}
const userIsEC = isEC(userEmail);

const db = env.DB;
const [responses, comments, audit] = db
  ? await Promise.all([
      listResponses(db, projectSlug),
      listAllComments(db, projectSlug),
      listAllAudit(db, projectSlug),
    ])
  : [[], [], [] as AuditRow[]];
const responsesById = new Map(responses.map((r) => [r.question_id, r]));
const commentsByQuestion = new Map<string, CommentRow[]>();
for (const c of comments) {
  const arr = commentsByQuestion.get(c.question_id);
  if (arr) arr.push(c);
  else commentsByQuestion.set(c.question_id, [c]);
}
const auditByQuestion = new Map<string, AuditRow[]>();
for (const a of audit) {
  const arr = auditByQuestion.get(a.question_id);
  if (arr) arr.push(a);
  else auditByQuestion.set(a.question_id, [a]);
}

const allSections = listSections(projectSlug);
const idx = allSections.findIndex((s) => s.slug === section.slug);
const prev = idx > 0 ? allSections[idx - 1] : null;
const next = idx < allSections.length - 1 ? allSections[idx + 1] : null;
---
<BaseLayout title={`${section.id}. ${section.title}`}>
  <div class="page-meta">
    <p class="breadcrumb">
      {userIsEC && (
        <>
          <a href="/">Discovery Portal</a>
          <span class="sep">›</span>
        </>
      )}
      <a href={`/${projectSlug}`}>{userIsEC ? project.title : `← ${project.title}`}</a>
    </p>
    {userIsEC && (
      <a
        class="edit-on-github"
        href={`https://github.com/electriccitizen/discovery/edit/main/content/projects/${projectSlug}/worksheet/${sectionSlug}.md`}
        target="_blank"
        rel="noopener noreferrer"
      >Edit on GitHub <span class="edit-on-github-arrow" aria-hidden="true">↗</span></a>
    )}
  </div>

  <h1>
    <span class="section-id-large">{section.id}</span>
    <span class="section-title-large">{section.title}</span>
  </h1>

  {section.introHtml && (
    <section class="section-intro">
      <h2>What we currently understand</h2>
      <div set:html={section.introHtml} />
    </section>
  )}

  <section class="section-questions">
    <h2>Questions for you ({section.questions.length})</h2>
    <ol class="question-list">
      {section.questions.map((q) => (
        <li>
          <QuestionCard
            question={q}
            projectSlug={projectSlug}
            response={responsesById.get(q.id) ?? null}
            comments={commentsByQuestion.get(q.id) ?? []}
            audit={auditByQuestion.get(q.id) ?? []}
          />
        </li>
      ))}
    </ol>
  </section>

  <nav class="section-nav">
    {prev && (
      <a class="section-nav-prev" href={`/${projectSlug}/section/${prev.slug}`}>
        <span class="nav-label">← Previous</span>
        <span class="nav-target">{prev.id}. {prev.title}</span>
      </a>
    )}
    {next && (
      <a class="section-nav-next" href={`/${projectSlug}/section/${next.slug}`}>
        <span class="nav-label">Next →</span>
        <span class="nav-target">{next.id}. {next.title}</span>
      </a>
    )}
  </nav>
</BaseLayout>
