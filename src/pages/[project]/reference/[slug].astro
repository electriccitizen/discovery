---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getProject, getReference } from '../../../lib/projects.ts';
import { canAccessProject, isEC, getAuthEmail } from '../../../lib/access.ts';

const projectSlug = Astro.params.project;
const refSlug = Astro.params.slug;
if (!projectSlug || !refSlug) return new Response(null, { status: 404 });

const project = getProject(projectSlug);
const ref = getReference(projectSlug, refSlug);
if (!project || !ref) return new Response(null, { status: 404 });

const userEmail = getAuthEmail(Astro.request);
if (!userEmail || !canAccessProject(userEmail, project)) {
  return new Response(null, { status: 404 });
}
const userIsEC = isEC(userEmail);
---
<BaseLayout title={ref.title}>
  <div class="page-meta">
    <p class="breadcrumb">
      {userIsEC && (
        <>
          <a href="/">Discovery Portal</a>
          <span class="sep">›</span>
          <a href={`/${projectSlug}`}>{project.title}</a>
          <span class="sep">›</span>
          <span>Reference</span>
        </>
      )}
      {!userIsEC && (
        <a href={`/${projectSlug}`}>← {project.title}</a>
      )}
    </p>
    {userIsEC && (
      <a
        class="edit-on-github"
        href={`https://github.com/electriccitizen/discovery/edit/main/content/projects/${projectSlug}/references/${refSlug}.md`}
        target="_blank"
        rel="noopener noreferrer"
      >Edit on GitHub <span class="edit-on-github-arrow" aria-hidden="true">↗</span></a>
    )}
  </div>

  <article class="reference-doc" set:html={ref.html} />
</BaseLayout>
