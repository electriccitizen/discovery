    <section class="a11y" style="max-width: 80rem;">
      <h2 style="margin-top:2.5rem">A11y — contrast ratios (WCAG)</h2>
      <p style="color:#71717a; font-size:0.85rem; margin:0 0 1rem">
        Computed in your browser from the actual hex values. AA = 4.5:1 for body text, 3:1 for large/UI.
        AAA = 7:1 for body text. Failures highlighted in red.
      </p>
      <table id="a11y-table">
        <thead>
          <tr>
            <th>Combo</th>
            <th>Sample</th>
            <th>Ratio</th>
            <th>Verdict</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </section>

    <script>
      // WCAG relative luminance + contrast ratio
      function lum(hex) {
        const c = hex.replace('#', '');
        const r = parseInt(c.slice(0, 2), 16) / 255;
        const g = parseInt(c.slice(2, 4), 16) / 255;
        const b = parseInt(c.slice(4, 6), 16) / 255;
        const adj = (v) => (v <= 0.03928 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4));
        return 0.2126 * adj(r) + 0.7152 * adj(g) + 0.0722 * adj(b);
      }
      function ratio(fg, bg) {
        const l1 = lum(fg), l2 = lum(bg);
        const [a, b] = l1 > l2 ? [l1, l2] : [l2, l1];
        return (a + 0.05) / (b + 0.05);
      }
      function verdict(r) {
        if (r >= 7) return ['pass-aaa', 'AAA'];
        if (r >= 4.5) return ['pass-aa', 'AA'];
        if (r >= 3) return ['pass-aa', 'AA (large)'];
        return ['fail', 'FAIL'];
      }
      const combos = [
        ['CURRENT — ink on paper', '#0a0a0a', '#fafafa', 'body text'],
        ['CURRENT — ink-soft on paper', '#3f3f46', '#fafafa', 'secondary text'],
        ['CURRENT — ink-muted on paper', '#71717a', '#fafafa', 'tertiary text / labels'],
        ['CURRENT — ink-faint on paper', '#a1a1aa', '#fafafa', 'placeholders / decorative'],
        ['CURRENT — sky-deep on sky-soft (priority tag)', '#075985', '#bae6fd', 'TAG'],
        ['CURRENT — rust-deep on rust-soft (clarif tag)', '#7c2d12', '#fed7aa', 'TAG'],
        ['CURRENT — #6e4d0c on amber-soft (answered)', '#6e4d0c', '#f7eccc', 'PILL'],
        ['CURRENT — moss on moss-soft (in_progress)', '#15803d', '#dcfce7', 'PILL'],
        ['CURRENT — white on navy (EC role)', '#ffffff', '#1e3a5f', 'CHIP'],
        ['CURRENT — white on rust (priority high)', '#ffffff', '#c2410c', 'CHIP'],
        ['CURRENT — white on teal client', '#ffffff', '#0e7490', 'CHIP'],
        ['PROPOSED — yellow-deep on yellow-soft', '#713f12', '#fef3c7', 'TAG'],
        ['PROPOSED — navy on blue-soft', '#1e3a5f', '#c8d8e8', 'TAG'],
        ['PROPOSED — pink-deep on pink-soft', '#6b1c2c', '#f5cfcf', 'TAG'],
        ['PROPOSED — white on client stone', '#ffffff', '#57534e', 'CHIP'],
        ['PROPOSED — moss-deep on moss-soft', '#14532d', '#d1fae5', 'PILL'],
      ];
      const tbody = document.querySelector('#a11y-table tbody');
      for (const [label, fg, bg, sample] of combos) {
        const r = ratio(fg, bg);
        const [cls, v] = verdict(r);
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${label}</td>
          <td><span class="sample" style="background:${bg}; color:${fg}">${sample} Aa</span></td>
          <td class="ratio">${r.toFixed(2)}:1</td>
          <td><span class="verdict ${cls}">${v}</span></td>
        `;
        tbody.appendChild(tr);
      }
    </script>
